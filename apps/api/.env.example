DATABASE_URL="postgresql://postgres:postgres@localhost:5435/video_meetings?schema=public"

JWT_SECRET="change-me"
JWT_EXPIRES_IN="3600"

# apps/web's dev server defaults to :3000, so the API must not also default there
PORT="3001"
CORS_ORIGIN="http://localhost:3000"

# Local disk root for uploaded meeting files (gitignored; created on demand)
FILE_STORAGE_ROOT="./storage/uploads"

# Hard cap on a single uploaded file, in bytes (default 500 MB)
MAX_UPLOAD_SIZE_BYTES="524288000"
